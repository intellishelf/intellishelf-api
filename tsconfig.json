{
  "compilerOptions": {
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "es2022",
    "allowJs": true,
    "module": "CommonJS",
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "moduleResolution": "node",
    "isolatedModules": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "./dist"
  }
}
