{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Intellishelf API",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": [
        "run",
        "--project",
        "src/Intellishelf.Api/Intellishelf.Api.csproj",
        "--launch-profile",
        "http"
      ],
      "port": 8080
    },
    {
      "name": "Intellishelf Frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend",
      "port": 3000
    }
  ]
}
